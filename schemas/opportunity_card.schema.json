    "signal": { "type": "string" },
    "user_anxiety": { "type": "string" },
    "product_hypothesis": { "type": "string" },
    "free_entry": { "type": "string" },
    "paid_offer": { "type": "string" },
    "distribution_test": { "type": "string" },
    "success_metric": { "type": "string" },
    "decision_rule": { "type": "string" },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
